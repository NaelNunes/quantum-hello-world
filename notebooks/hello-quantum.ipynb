   "source": [
    "from qiskit import QuantumCircuit\n",
    "\n",
    "qc = QuantumCircuit(2)\n",
    "\n",
    "qc.h(0)\n",
    "qc.h(1)\n",
    "# qc.cx(0, 1)\n",
    "\n",
    "qc.measure_all()\n",
    "\n",
    "qc.draw(\"text\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "7eaa5bb3-ff96-4e5a-98ae-cb0f15bfa06a",
